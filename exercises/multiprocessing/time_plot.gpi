set terminal svg size 800,600 enhanced font 'Verdana,10' background "white"
set output 'time_plot.svg'

set title 'runtime vs. Number of threads for Harmonic series'
set xlabel 'Number of threads'
set ylabel 'Time (seconds)'

set xtics 1
set grid

plot 'out.times' using 1:2 with linespoints linewidth 2 pointtype 7 title 'Wall-clock time', \
     'out.times' using 1:3 with linespoints linewidth 2 pointtype 5 title 'Total CPU-time'
