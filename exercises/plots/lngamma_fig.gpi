set terminal svg size 800, 600 background "white"
set output "lngamma_fig.svg"

set title "ln(gamma) function (stirling approximation)"
set xlabel "x"
set ylabel "ln(gamma(x))"
set grid

plot "lngamma_data.txt" with lines linewidth 2 title "lngamma(x)", \
     "lngamma_points.txt" with points pointtype 7 pointsize 1.5 linecolor "red" title "Points of lngamma function"