set terminal svg size 800, 600 background "white"
set output "erf_fig.svg"

set title "Error function (stirling approximation)"
set xlabel "x"
set ylabel "erf(x)"
set grid

plot "erf_data.txt" with lines linewidth 2 title "erf(x)", \
     "erf_points.txt" with points pointtype 7 pointsize 1.5 linecolor "red" title "Points of error function"